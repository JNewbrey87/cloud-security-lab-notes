<group name="local,">

  <!-- Rule 100002: Windows Failed Logon (Event 4625) -->
  <!-- Fires on every failed Windows logon attempt on any monitored host -->
  <!-- MITRE: T1110 (Brute Force) -->
  <!-- Validated: Lab P1-1a (Event 4625 on domain-joined jump box, 17x confirmed) -->
  <rule id="100002" level="10">
    <if_group>windows</if_group>
    <field name="win.system.eventID">^4625$</field>
    <description>Custom: Windows failed logon attempt detected (Event 4625)</description>
    <mitre>
      <id>T1110</id>
    </mitre>
  </rule>

  <!-- Rule 100003: SSH Brute Force (5+ failed attempts in 60s from same source IP) -->
  <!-- Fires when Wazuh's built-in SSH failure decoder (5700) fires 5+ times in 60s from same IP -->
  <!-- MITRE: T1110 (Brute Force), T1110.001 (Password Guessing) -->
  <!-- Validated: Lab P1-1b (Hydra against LAB-UBTU SSH service from LAB-KALI) -->
  <!-- NOTE: Ubuntu 22.04 sshd-session fires rule 5700 (NOT 5716) — confirmed via wazuh-logtest -->
  <!-- NOTE: If srclimit_penalise blocks Hydra early, add PerSourcePenalties no to /etc/ssh/sshd_config -->
  <rule id="100003" level="10" frequency="5" timeframe="60">
    <if_matched_sid>5700</if_matched_sid>
    <same_source_ip />
    <description>Custom: SSH brute force attack detected: 5+ failed attempts in 60 sec from same source IP</description>
    <mitre>
      <id>T1110</id>
      <id>T1110.001</id>
    </mitre>
  </rule>

  <!-- Rule 100004: Lateral Movement — Explicit Credential Use Outbound (Event 4648) -->
  <!-- Fires on the SOURCE host when Windows records explicit credential use toward a remote target -->
  <!-- Captures the outbound side of a lateral movement attempt (net use, Invoke-Command, etc.) -->
  <!-- MITRE: T1021.002 (Remote Services: SMB/Windows Admin Shares) -->
  <!-- Validated: Lab P1-1d (net use \\DC\ADMIN$ from LAB-WSJP-25, 3 hits confirmed) -->
  <rule id="100004" level="12">
    <if_group>windows</if_group>
    <field name="win.system.eventID">^4648$</field>
    <description>Custom: Explicit credential use toward remote host detected - possible lateral movement (Event 4648)</description>
    <mitre>
      <id>T1021.002</id>
    </mitre>
  </rule>

  <!-- Rule 100005: Lateral Movement Arrival — Failed Network Logon on Tier 0 DC (Event 4625, logon type 3) -->
  <!-- Fires on the TARGET DC when an incoming network logon attempt fails -->
  <!-- logonType 3 = network logon; without this filter, all interactive failed logons (type 2) also trigger -->
  <!-- Level 14: any network auth attempt reaching the Tier 0 DC is treated as higher severity than activity on Tier 1 hosts -->
  <!-- MITRE: T1021.002 (Remote Services: SMB/Windows Admin Shares) -->
  <!-- Validated: Lab P1-1d (incoming 4625 type 3 on LAB-WSDC-22 from LAB-WSJP-25, NTLM auth) -->
  <!-- KEY: net use targeting DC by IP falls back to NTLM (not Kerberos); 4771 is NOT generated by this path -->
  <rule id="100005" level="14">
    <if_group>windows</if_group>
    <field name="win.system.eventID">^4625$</field>
    <field name="win.eventdata.logonType">^3$</field>
    <description>Custom: Failed network logon on Tier 0 DC - possible lateral movement arrival (Event 4625, logon type 3)</description>
    <mitre>
      <id>T1021.002</id>
    </mitre>
  </rule>

</group>
